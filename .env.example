# ═══════════════════════════════════════════════════════════════════════════
# CobraAI — referencia maestra de variables de entorno (desarrollo local)
# Copiar a .env en la raíz y completar las claves marcadas con [REQUERIDO].
# Guía detallada: docs/ENV.md
# Setup rápido: bash scripts/env-setup.sh
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=development
WEB_ORIGIN=http://localhost:3001

# ─── Clerk [REQUERIDO para auth] ───────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Base de datos [REQUERIDO] ─────────────────────────────────────────────
# Postgres en Docker expone puerto 5433 (infra/docker/docker-compose.yml)
DATABASE_URL=postgresql://cobrai:cobrai_dev@localhost:5433/cobrai_dev?schema=public

# ─── Redis / Kafka [REQUERIDO para import async y eventos] ─────────────────
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=cobrai-dev

# ─── URLs de microservicios (puertos locales) ───────────────────────────────
# Web :3001 · Gateway :3000 · Portfolios :3011 · Workflows :3002
# Notifications :3003 · Payments :3004
NEXT_PUBLIC_API_URL=http://localhost:3000
SERVICE_PORTFOLIOS_URL=http://localhost:3011
SERVICE_WORKFOLIOS_URL=http://localhost:3002
SERVICE_NOTIFICATIONS_URL=http://localhost:3003
SERVICE_PAYMENTS_URL=http://localhost:3004
PAYMENTS_SERVICE_URL=http://localhost:3004
PAYMENT_LINK_BASE_URL=http://localhost:3001/pay

# ─── API Gateway ───────────────────────────────────────────────────────────
PORT=3000
RATE_LIMIT_IP_PER_MIN=100
RATE_LIMIT_TENANT_PER_MIN=1000

# ─── Seed demo (tras crear org en Clerk) ───────────────────────────────────
# pnpm db:seed:align
# SEED_TENANT_ID=org_xxxxxxxxxxxxxxxxxxxxx
# SEED_TENANT_NAME=Mi Empresa

# ─── SendGrid [opcional — emails reales] ───────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@cobrai.dev
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# ─── Twilio [opcional — SMS reales] ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Pagos [opcional — checkout real] ──────────────────────────────────────
CONEKTA_PRIVATE_KEY=
CONEKTA_WEBHOOK_SECRET=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ─── Workflows (escalación legal) ──────────────────────────────────────────
LEGAL_ESCALATION_AGING_DAYS=180
LEGAL_ESCALATION_MAX_SCORE=20
LEGAL_ESCALATION_AMOUNT_USD=10000

# ─── Tests E2E Playwright [opcional] ─────────────────────────────────────────
# E2E_AUTH_READY=1
# E2E_DEBT_ID=

# ─── Observabilidad [opcional] ─────────────────────────────────────────────
SENTRY_DSN=
BETTER_STACK_SOURCE_TOKEN=
